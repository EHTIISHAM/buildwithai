# ─── BuildWithAI environment ───────────────────────────────
# Copy this file to ".env" and fill in your real values.

# Session signing secret (any long random string)
SESSION_SECRET=replace-with-a-long-random-string

# Google OAuth (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Where the app is hosted (no trailing slash)
# Local:  http://localhost:8000
# Prod:   https://yourdomain.com
BASE_URL=http://localhost:8000

# MongoDB Atlas — paste your FULL connection string here
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=buildwithai

# Token to protect /admin/signups export endpoint
ADMIN_TOKEN=set-an-admin-token
